# --- Módulo de incidentes CCB — variables requeridas ---

APP_NAME="CCB Incidentes"
APP_ENV=production
APP_DEBUG=false          # NUNCA true en producción: expone trazas y credenciales
APP_URL=https://ccbol.org

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=ccb_incidentes
DB_USERNAME=ccb_app      # usuario con permisos mínimos (sin DROP/ALTER en producción)
DB_PASSWORD=

# SMTP institucional (V2, sección 11)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=incidentes@ccbol.org
MAIL_FROM_NAME="CCB Bolivia"

# Google reCAPTCHA (V2, sección 8.1)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Sesiones y cookies seguras
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
